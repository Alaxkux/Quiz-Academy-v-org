{
  "name": "quiz-academy",
  "version": "4.1.0",
  "description": "Quiz Academy — Full-stack learning platform",
  "main": "server/index.js",
  "scripts": {
    "start":       "node server/index.js",
    "dev":         "nodemon server/index.js",
    "install:all": "npm install && cd quiz-academy-react && npm install",
    "dev:all":     "concurrently \"npm run dev\" \"cd quiz-academy-react && npm run dev\""
  },
  "dependencies": {
    "bcryptjs":           "^2.4.3",
    "connect-mongo":      "^5.1.0",
    "cookie-parser":      "^1.4.6",
    "cors":               "^2.8.5",
    "dotenv":             "^16.3.1",
    "express":            "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session":    "^1.17.3",
    "google-auth-library": "^9.6.3",
    "helmet":             "^7.1.0",
    "jsonwebtoken":       "^9.0.2",
    "mongoose":           "^8.0.3",
    "multer":             "^1.4.5-lts.1",
    "nodemailer":         "^6.9.8",
    "pdf-parse":          "^1.1.1",
    "validator":          "^13.11.0",
    "web-push":           "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
