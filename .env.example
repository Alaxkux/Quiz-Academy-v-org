# ================================================================
# QUIZ ACADEMY — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ================================================================

# ── SERVER ──
PORT=3000
NODE_ENV=development

# ── MONGODB ──
# Get this from MongoDB Atlas: Clusters > Connect > Connect your application
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://QuizAcademy-V2:quizacademy2026@aiquizcluster.sthmoye.mongodb.net/quiz_academy?retryWrites=true&w=majority&appName=AIQuizCluster

# ── JWT ──
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=QuizAcademy_JWT_Secret_9x2mK8pL4nQ7vR3wY6tJ5hD1
JWT_EXPIRES_IN=7d

# ── SESSION ──
# Generate separately from JWT secret
SESSION_SECRET=QuizAcademy_Session_Secret_3fN8wX2mP9kL6rT4vQ7yH5j1

# ── GEMINI AI (FREE) ──
# Get your free API key at: https://aistudio.google.com/app/apikey
# Free tier: 15 requests/min, 1500 requests/day — no billing needed!
GEMINI_API_KEY=AIzaSyAgyPrPzmosBL4WtZvWLt1DxSGdkPVvXKU

# ── EMAIL (for password reset) ──
# Use a Gmail account + App Password (NOT your real Gmail password)
# How to get App Password:
#   1. Go to myaccount.google.com
#   2. Security → 2-Step Verification → App passwords
#   3. Create one for "Quiz Academy"
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# ── GOOGLE OAUTH ──
# How to get your Client ID:
#   1. Go to https://console.cloud.google.com
#   2. Create/select a project
#   3. APIs & Services → Credentials → Create → OAuth 2.0 Client ID
#   4. Application type: Web application
#   5. Authorized JavaScript origins: http://localhost:3000
#   6. Copy the Client ID below
GOOGLE_CLIENT_ID=285772500770-mtv802co3ehrf1sb6nsbql1nfdspk1h6.apps.googleusercontent.com

# ── CORS ──
# Your frontend URL (in production, set to your actual domain)
CLIENT_URL=http://localhost:3000

